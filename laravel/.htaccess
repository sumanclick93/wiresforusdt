<IfModule mod_rewrite.c>
    RewriteEngine On

    # Redirect /public/about to /about (clean URLs)
    RewriteCond %{THE_REQUEST} /public/([^\s?]*) [NC]
    RewriteRule ^public/(.*)$ /%1 [R=301,L]

    # Rewrite all requests to the public/ directory internally
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block direct access to sensitive files/directories (security reinforcement)
RedirectMatch 404 /\.(git|env)
RedirectMatch 404 ^/(src|storage|database|htacess)(/|$)
